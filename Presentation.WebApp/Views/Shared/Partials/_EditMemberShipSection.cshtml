@model MyAccountViewModel
<section class="body-wrapper">
    @if (!string.IsNullOrWhiteSpace(ViewData["Message"]?.ToString()))
                    {
                        if (ViewData["MessageType"]?.ToString() == "error")
                        {
                            <div class="error-in-text">
                                @ViewData["Message"]
                            </div>
                        }
                        else
                        {
                            <div class="success-in-text">
                                @ViewData["Message"]
                            </div>
                        }
                    }
    <form asp-controller="MemeberShip" asp-action="CreateMembership" asp-area="" method="post">
        <h2>New Membership</h2>
        <div class="signin-bar">
            <label asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.MembershipName"></label>
            <input asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.MembershipName" />
            <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.MembershipName"></span>
        </div>
        <div class="signin-bar">
            <label asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.description"></label>
            <input asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.description" />
            <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.description"></span>
        </div>
        <div class="signin-bar">
            <label asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.pricing"></label>
            <input asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.pricing" />
            <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.pricing"></span>
        </div>
        <div class="signin-bar">
            <label asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.monthlyDuration"></label>
            <input asp-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.monthlyDuration" />
            <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.MembershipForm.monthlyDuration"></span>
        </div>

        <button type="button" id="add-benefit">Add Benefit</button>

        <div id="new-benefits-container">
            @if (Model.MyMembershipViewModel.MembershipViewModel.MembershipForm?.Benefits != null)
            {
                for (var i = 0; i < Model.MyMembershipViewModel.MembershipViewModel.MembershipForm.Benefits.Count; i++)
                {
                    <div class="signin-bar benefit-item">
                        <label>Benefit</label>
                        <input type="text" name="MyMembershipViewModel.MembershipViewModel.MembershipForm.Benefits[@i].benefit" value="@Model.MyMembershipViewModel.MembershipViewModel.MembershipForm.Benefits[i].benefit" />
                        <button type="button" class="remove-benefit">Remove</button>
                    </div>
                }
            }
        </div>
        <button type="submit">Create</button>
    </form>

    <hr />
    <div>
        <h2>Edit Membership</h2>
        @foreach (var membership in Model.MyMembershipViewModel.MembershipViewModel.Memberships)
        {
            <hr />
            <form class="update-membership-form" asp-controller="MemeberShip" asp-action="UpdateMembership" asp-area="" method="post">
                <input type="hidden" name="id" value="@membership.Id" />

                <div class="signin-bar">
                    <label asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.MembershipName"></label>
                    <input asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.MembershipName" value="@membership.Name"/>
                    <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.MembershipName"></span>
                </div>
                <div class="signin-bar">
                    <label asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.description"></label>
                    <input asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.description" value="@membership.Description"/>
                    <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.description"></span>
                </div>
                <div class="signin-bar">
                    <label asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.pricing"></label>
                    <input asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.pricing" value="@membership.Pricing"/>
                    <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.pricing"></span>
                </div>
                <div class="signin-bar">
                    <label asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.monthlyDuration"></label>
                    <input asp-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.monthlyDuration" value="@membership.MonthlyDuration"/>
                    <span asp-validation-for="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.monthlyDuration"></span>
                </div>

                <div class="benefits-list">
                    @if (membership.Benefits.Count() != 0)
                    {
                        var idx = 0;
                        foreach (var benefit in membership.Benefits)
                        {
                            <div class="signin-bar benefit-item">
                                <label>Benefit</label>
                                <input type="hidden" name="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.Benefits[@idx].id" value="@benefit.Id" />
                                <input type="text" name="MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.Benefits[@idx].benefit" value="@benefit.Benefit" />
                                <button type="button" class="remove-benefit">Remove</button>
                            </div>
                            idx++;
                        }
                    }
                </div>

                <button type="button" class="add-benefit-btn">Add Benefit</button>

                <button type="submit">Update</button>
            </form>

            <form asp-controller="MemeberShip" asp-action="RemoveMembership" method="post">
                <input type="hidden" name="id" value="@membership.Id" />
                <input type="submit" value="Delete" />
            </form>
        }
    </div>
</section>

<script>
    (function () {
        // Helper to reindex benefit inputs within a container
        function reindexBenefits(container, namePrefix, includeId) {
            const items = container.querySelectorAll('.benefit-item');
            items.forEach((item, index) => {
                const textInput = item.querySelector('input[type="text"]');
                if (textInput) {
                    textInput.name = `${namePrefix}[${index}].benefit`;
                }
                if (includeId) {
                    let hidden = item.querySelector('input[type="hidden"]');
                    if (!hidden) {
                        hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        item.insertBefore(hidden, textInput);
                    }
                    hidden.name = `${namePrefix}[${index}].id`;
                }
            });
        }

        // Add benefit for Create form
        const addCreateBtn = document.getElementById('add-benefit');
        const createContainer = document.getElementById('new-benefits-container');
        const createNamePrefix = 'MyMembershipViewModel.MembershipViewModel.MembershipForm.Benefits';

        if (addCreateBtn) {
            addCreateBtn.addEventListener('click', function () {
                const index = createContainer.querySelectorAll('.benefit-item').length;
                const div = document.createElement('div');
                div.className = 'signin-bar benefit-item';
                div.innerHTML = '<label>Benefit</label>' +
                    `<input type="text" name="${createNamePrefix}[${index}].benefit" value="" />` +
                    '<button type="button" class="remove-benefit">Remove</button>';
                createContainer.appendChild(div);
            });
        }

        // Delegate remove clicks for both create and update containers
        document.addEventListener('click', function (e) {
            if (e.target && e.target.classList.contains('remove-benefit')) {
                const item = e.target.closest('.benefit-item');
                if (!item) return;
                const benefitsParent = item.parentElement;
                const form = e.target.closest('form');

                item.remove();

                // Decide which prefix to use based on the form
                if (form) {
                    // Update form - use UpdateMembershipForm prefix
                    const updatePrefix = 'MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.Benefits';
                    const benefitsList = form.querySelector('.benefits-list');
                    if (benefitsList && benefitsList.contains(benefitsParent)) {
                        reindexBenefits(benefitsList, updatePrefix, true);
                        return;
                    }
                }

                // Otherwise, assume create container
                if (createContainer && createContainer.contains(benefitsParent)) {
                    reindexBenefits(createContainer, createNamePrefix, false);
                }
            }
        });

        // Add benefit for each update form (multiple forms on the page)
        const updateForms = document.querySelectorAll('form.update-membership-form');
        updateForms.forEach(form => {
            const addBtn = form.querySelector('.add-benefit-btn');
            const benefitsList = form.querySelector('.benefits-list');
            const updateNamePrefix = 'MyMembershipViewModel.MembershipViewModel.UpdateMembershipForm.Benefits';

            if (!addBtn || !benefitsList) return;

            addBtn.addEventListener('click', function () {
                const index = benefitsList.querySelectorAll('.benefit-item').length;
                const div = document.createElement('div');
                div.className = 'signin-bar benefit-item';

                // Include hidden id for update forms so model binder can map existing items and new ones have empty id
                div.innerHTML = '<label>Benefit</label>' +
                    `<input type="hidden" name="${updateNamePrefix}[${index}].id" value="" />` +
                    `<input type="text" name="${updateNamePrefix}[${index}].benefit" value="" />` +
                    '<button type="button" class="remove-benefit">Remove</button>';

                benefitsList.appendChild(div);
            });
        });
    })();
</script>